{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://consultant-booking-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://consultant-booking-backend.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://consultant-booking-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://consultant-booking-backend.onrender.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://consultant-booking-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://consultant-booking-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
